{
  "name": "video-editor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 3001",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "wasm:build": "wasm-pack build wasm --target bundler --out-dir ../src/wasm-pkg",
    "wasm:dev": "wasm-pack build wasm --target bundler --out-dir ../src/wasm-pkg --dev"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "0.10.33",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "zustand": "5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.0.0",
    "@types/react": "19.1.0",
    "@types/react-dom": "19.1.0",
    "@vitejs/plugin-react": "4.3.0",
    "tailwindcss": "4.0.0",
    "typescript": "~5.7.0",
    "vite": "6.0.0",
    "vite-plugin-top-level-await": "1.4.4",
    "vite-plugin-wasm": "3.3.0"
  }
}
